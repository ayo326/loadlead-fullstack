{
  "$schema": "https://raw.githubusercontent.com/markdown-confluence/markdown-confluence/main/packages/lib/schema.json",

  "contentRoot": "docs",
  "folderTitle": true,

  "confluenceBaseUrl": "${CONFLUENCE_BASE_URL}",
  "confluenceParentId": "${CONFLUENCE_PARENT_PAGE_ID}",
  "confluenceSpaceKey": "${CONFLUENCE_SPACE_KEY}",

  "atlassianUserName": "${CONFLUENCE_EMAIL}",
  "atlassianApiToken":  "${CONFLUENCE_API_TOKEN}",

  "ignore": [
    "**/CREDENTIALS.md",
    "**/FINAL_IMPLEMENTATION_CHECKLIST.md",
    "**/node_modules/**"
  ],

  "firstHeadingPageTitle": false
}
