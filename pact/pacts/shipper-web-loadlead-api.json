{
  "consumer": {
    "name": "shipper-web"
  },
  "interactions": [
    {
      "description": "a request for a load that does not belong to the authenticated shipper",
      "providerStates": [
        {
          "name": "a load exists belonging to a different shipper"
        }
      ],
      "request": {
        "headers": {
          "Cookie": "token=test-shipper-jwt"
        },
        "method": "GET",
        "path": "/api/shipper/loads/load_belongs_to_other"
      },
      "response": {
        "body": {
          "error": "Load not found"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.error": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 404
      }
    },
    {
      "description": "a request for the shipper loads list",
      "providerStates": [
        {
          "name": "the authenticated shipper has at least one posted load"
        }
      ],
      "request": {
        "headers": {
          "Cookie": "token=test-shipper-jwt"
        },
        "method": "GET",
        "path": "/api/shipper/loads"
      },
      "response": {
        "body": {
          "loads": [
            {
              "createdAt": 1700000000000,
              "deliveryCity": "Dallas",
              "deliveryState": "TX",
              "equipmentType": "DRY_VAN",
              "loadId": "load_aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee",
              "pickupCity": "Houston",
              "pickupState": "TX",
              "rateAmount": 1200,
              "shipperId": "shipper_test_1",
              "status": "OPEN",
              "totalWeightLbs": 40000
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.loads": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.loads[*].createdAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.loads[*].deliveryCity": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.loads[*].deliveryState": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[A-Z]{2}$"
                }
              ]
            },
            "$.loads[*].equipmentType": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.loads[*].loadId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^load_[a-f0-9-]+$"
                }
              ]
            },
            "$.loads[*].pickupCity": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.loads[*].pickupState": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[A-Z]{2}$"
                }
              ]
            },
            "$.loads[*].rateAmount": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.loads[*].shipperId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^shipper_[a-zA-Z0-9_-]+$"
                }
              ]
            },
            "$.loads[*].status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^(DRAFT|OPEN|IN_TRANSIT|DELIVERED|CANCELED)$"
                }
              ]
            },
            "$.loads[*].totalWeightLbs": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to create a new draft load",
      "providerStates": [
        {
          "name": "the authenticated shipper has a complete profile"
        }
      ],
      "request": {
        "body": {
          "deliveryCity": "Dallas",
          "deliveryState": "TX",
          "equipmentType": "DRY_VAN",
          "pickupCity": "Houston",
          "pickupState": "TX",
          "rateAmount": 1200,
          "totalWeightLbs": 40000
        },
        "headers": {
          "Content-Type": "application/json",
          "Cookie": "token=test-shipper-jwt"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/shipper/loads"
      },
      "response": {
        "body": {
          "loadId": "load_aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee",
          "shipperId": "shipper_test_1",
          "status": "DRAFT"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.loadId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^load_[a-f0-9-]+$"
                }
              ]
            },
            "$.shipperId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^shipper_[a-zA-Z0-9_-]+$"
                }
              ]
            }
          }
        },
        "status": 201
      }
    },
    {
      "description": "a signup attempt carrying a valid beta invite token",
      "providerStates": [
        {
          "name": "BETA_MODE is on and a valid self-signup invite exists for the email"
        }
      ],
      "request": {
        "body": {
          "email": "invited@example.com",
          "inviteToken": "beta-invite-token-abc",
          "password": "a-strong-password",
          "role": "SHIPPER"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/auth/signup"
      },
      "response": {
        "body": {
          "token": "test-jwt",
          "user": {
            "betaUser": true,
            "cohort": "wave-1",
            "email": "invited@example.com",
            "invitedVia": "INVITE",
            "role": "SHIPPER",
            "userId": "user_test_1"
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.token": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.user": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.user.betaUser": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.user.cohort": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.user.email": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.user.invitedVia": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^(INVITE|ALLOWLIST)$"
                }
              ]
            },
            "$.user.role": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^SHIPPER$"
                }
              ]
            },
            "$.user.userId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^user_[a-zA-Z0-9_-]+$"
                }
              ]
            }
          }
        },
        "status": 201
      }
    },
    {
      "description": "a signup attempt with no invite token under private beta",
      "providerStates": [
        {
          "name": "BETA_MODE is on and the email is neither invited nor allowlisted"
        }
      ],
      "request": {
        "body": {
          "email": "outsider@example.com",
          "password": "a-strong-password",
          "role": "SHIPPER"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/auth/signup"
      },
      "response": {
        "body": {
          "error": "BETA_REQUIRED",
          "message": "LoadLead is currently in private beta. Request access on the waitlist and we will reach out when your spot opens."
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.error": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^BETA_REQUIRED$"
                }
              ]
            },
            "$.message": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 403
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.5.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "loadlead-api"
  }
}