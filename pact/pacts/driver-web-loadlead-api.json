{
  "consumer": {
    "name": "driver-web"
  },
  "interactions": [
    {
      "description": "a request for the driver affiliation status",
      "providerStates": [
        {
          "name": "the authenticated driver is affiliated with an owner operator"
        }
      ],
      "request": {
        "headers": {
          "Cookie": "token=test-driver-jwt"
        },
        "method": "GET",
        "path": "/api/driver/affiliation"
      },
      "response": {
        "body": {
          "carrier": {
            "entityId": "op_1f26205e-941e-46a3-8efb-ae61c1381e91",
            "entityType": "OWNER_OPERATOR"
          },
          "status": "AFFILIATED"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.carrier": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.carrier.entityId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.carrier.entityType": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^(OWNER_OPERATOR|CARRIER_ORG)$"
                }
              ]
            },
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^(AFFILIATED|UNAFFILIATED|NO_PROFILE)$"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request for the driver loadboard",
      "providerStates": [
        {
          "name": "the authenticated driver has at least one OFFERED load matched to their truck"
        }
      ],
      "request": {
        "headers": {
          "Cookie": "token=test-driver-jwt"
        },
        "method": "GET",
        "path": "/api/driver/loadboard"
      },
      "response": {
        "body": {
          "loads": [
            {
              "load": {
                "deliveryCity": "Dallas",
                "deliveryState": "TX",
                "equipmentType": "DRY_VAN",
                "loadId": "load_aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee",
                "pickupCity": "Houston",
                "pickupState": "TX",
                "rateAmount": 1200,
                "status": "OPEN"
              },
              "offer": {
                "expiresAt": 1700000000000,
                "offerId": "offer_abc123",
                "status": "OFFERED"
              }
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.loads": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.loads[*].load": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.loads[*].load.deliveryCity": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.loads[*].load.deliveryState": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[A-Z]{2}$"
                }
              ]
            },
            "$.loads[*].load.equipmentType": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.loads[*].load.loadId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^load_[a-f0-9-]+$"
                }
              ]
            },
            "$.loads[*].load.pickupCity": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.loads[*].load.pickupState": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[A-Z]{2}$"
                }
              ]
            },
            "$.loads[*].load.rateAmount": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.loads[*].load.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^(OPEN|IN_TRANSIT|DELIVERED|CANCELED)$"
                }
              ]
            },
            "$.loads[*].offer": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.loads[*].offer.expiresAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.loads[*].offer.offerId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^offer_[a-zA-Z0-9_-]+$"
                }
              ]
            },
            "$.loads[*].offer.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^(OFFERED|ACCEPTED|DECLINED|EXPIRED)$"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request for the loadboard from an unaffiliated driver",
      "providerStates": [
        {
          "name": "the authenticated driver has NO carrier of record"
        }
      ],
      "request": {
        "headers": {
          "Cookie": "token=test-unaffiliated-driver-jwt"
        },
        "method": "GET",
        "path": "/api/driver/loadboard"
      },
      "response": {
        "body": {
          "loads": []
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.5.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "loadlead-api"
  }
}