{
  "consumer": {
    "name": "admin-console"
  },
  "interactions": [
    {
      "description": "a request for the paginated admin orgs list",
      "providerStates": [
        {
          "name": "the admin org list has at least one active and one suspended org"
        }
      ],
      "request": {
        "headers": {
          "Cookie": "token=test-staff-admin-jwt"
        },
        "method": "GET",
        "path": "/api/admin/orgs",
        "query": {
          "limit": [
            "50"
          ],
          "status": [
            "all"
          ]
        }
      },
      "response": {
        "body": {
          "cursor": null,
          "orgs": [
            {
              "capabilities": [
                "CARRIER"
              ],
              "isSuspended": false,
              "memberCount": 7,
              "name": "Acme Trucking",
              "orgId": "org_carrier_1"
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.cursor": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.orgs": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.orgs[*].capabilities": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.orgs[*].capabilities[*]": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^(CARRIER|SHIPPER|RECEIVER)$"
                }
              ]
            },
            "$.orgs[*].isSuspended": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.orgs[*].memberCount": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.orgs[*].name": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.orgs[*].orgId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^org_[a-zA-Z0-9_-]+$"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to suspend an org with a valid reason",
      "providerStates": [
        {
          "name": "a STAFF_ADMIN is logged in and an active org exists at org_to_suspend"
        }
      ],
      "request": {
        "body": {
          "reason": "fraud investigation"
        },
        "headers": {
          "Content-Type": "application/json",
          "Cookie": "token=test-staff-admin-jwt"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/admin/orgs/org_to_suspend/suspend"
      },
      "response": {
        "body": {
          "ok": true,
          "orgId": "org_to_suspend",
          "suspended": true
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.ok": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.orgId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^org_[a-zA-Z0-9_-]+$"
                }
              ]
            },
            "$.suspended": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to suspend an org without a reason",
      "providerStates": [
        {
          "name": "a STAFF_ADMIN is logged in and an active org exists at org_to_suspend"
        }
      ],
      "request": {
        "body": {},
        "headers": {
          "Content-Type": "application/json",
          "Cookie": "token=test-staff-admin-jwt"
        },
        "method": "POST",
        "path": "/api/admin/orgs/org_to_suspend/suspend"
      },
      "response": {
        "body": {
          "error": "reason is required (at least 6 characters)"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.error": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 400
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.5.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "loadlead-api"
  }
}