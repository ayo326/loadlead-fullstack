{
  "consumer": {
    "name": "receiver-web"
  },
  "interactions": [
    {
      "description": "a request for a load that does not belong to this receiver",
      "providerStates": [
        {
          "name": "a load exists destined for a different receiver facility"
        }
      ],
      "request": {
        "headers": {
          "Cookie": "token=test-receiver-jwt"
        },
        "method": "GET",
        "path": "/api/receiver/loads/load_other_receiver"
      },
      "response": {
        "body": {
          "error": "Load not found"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.error": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 404
      }
    },
    {
      "description": "a request for the receiver incoming list",
      "providerStates": [
        {
          "name": "a receiver has 2 in-transit shipments assigned to their facility"
        }
      ],
      "request": {
        "headers": {
          "Cookie": "token=test-receiver-jwt"
        },
        "method": "GET",
        "path": "/api/receiver/incoming"
      },
      "response": {
        "body": {
          "loads": [
            {
              "assignedDriverId": "driver_abc",
              "deliveryCity": "Dallas",
              "deliveryState": "TX",
              "loadId": "load_aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee",
              "pickupCity": "Houston",
              "pickupState": "TX",
              "status": "IN_TRANSIT"
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.loads": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.loads[*].assignedDriverId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^driver_[a-zA-Z0-9_-]+$"
                }
              ]
            },
            "$.loads[*].deliveryCity": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.loads[*].deliveryState": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[A-Z]{2}$"
                }
              ]
            },
            "$.loads[*].loadId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^load_[a-f0-9-]+$"
                }
              ]
            },
            "$.loads[*].pickupCity": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.loads[*].pickupState": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[A-Z]{2}$"
                }
              ]
            },
            "$.loads[*].status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^IN_TRANSIT$"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to confirm delivery without first signing",
      "providerStates": [
        {
          "name": "a load IN_TRANSIT to this receiver has no RECEIVER_CONFIRM signature yet"
        }
      ],
      "request": {
        "body": {},
        "headers": {
          "Content-Type": "application/json",
          "Cookie": "token=test-receiver-jwt"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/receiver/loads/load_test_incoming/confirm"
      },
      "response": {
        "body": {
          "message": "RECEIVER_CONFIRM signature is required",
          "statusCode": 412
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.message": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.statusCode": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 412
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.5.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "loadlead-api"
  }
}