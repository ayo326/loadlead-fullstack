{
  "consumer": {
    "name": "oo-web"
  },
  "interactions": [
    {
      "description": "a request for the OO blended dashboard",
      "providerStates": [
        {
          "name": "an owner operator has 1 self-driver and 2 fleet drivers"
        }
      ],
      "request": {
        "headers": {
          "Cookie": "token=test-oo-jwt"
        },
        "method": "GET",
        "path": "/api/owner-operator/dashboard"
      },
      "response": {
        "body": {
          "activeLoads": 3,
          "fleetDrivers": [
            {
              "driverId": "driver_fleet_1",
              "isSelf": false,
              "status": "AVAILABLE"
            }
          ],
          "grossRevenue": 18500,
          "operatorId": "op_test_1",
          "selfDriver": {
            "driverId": "driver_oo_self",
            "isSelf": true,
            "status": "AVAILABLE"
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.activeLoads": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.fleetDrivers": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.fleetDrivers[*].driverId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^driver_[a-zA-Z0-9_-]+$"
                }
              ]
            },
            "$.fleetDrivers[*].isSelf": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.fleetDrivers[*].status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^(AVAILABLE|ON_LOAD|UNAVAILABLE)$"
                }
              ]
            },
            "$.grossRevenue": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.operatorId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^op_[a-zA-Z0-9_-]+$"
                }
              ]
            },
            "$.selfDriver": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.selfDriver.driverId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^driver_[a-zA-Z0-9_-]+$"
                }
              ]
            },
            "$.selfDriver.isSelf": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.selfDriver.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^(AVAILABLE|ON_LOAD|UNAVAILABLE)$"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request for the OO carrier-authority verification state",
      "providerStates": [
        {
          "name": "an owner operator has submitted FMCSA + KYB but not yet IDV"
        }
      ],
      "request": {
        "headers": {
          "Cookie": "token=test-oo-jwt"
        },
        "method": "GET",
        "path": "/api/owner-operator/verification"
      },
      "response": {
        "body": {
          "verification": {
            "entityType": "OWNER_OPERATOR",
            "fmcsaStatus": "active",
            "kybStatus": "PASSED",
            "verificationStatus": "PENDING"
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.verification": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.verification.entityType": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^OWNER_OPERATOR$"
                }
              ]
            },
            "$.verification.fmcsaStatus": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^(active|inactive|unknown)$"
                }
              ]
            },
            "$.verification.kybStatus": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^(PASSED|PENDING|FAILED)$"
                }
              ]
            },
            "$.verification.verificationStatus": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^(UNVERIFIED|PENDING|VERIFIED|REJECTED|EXPIRED)$"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request for the OO fleet invites list",
      "providerStates": [
        {
          "name": "an owner operator has 2 pending fleet driver invitations"
        }
      ],
      "request": {
        "headers": {
          "Cookie": "token=test-oo-jwt"
        },
        "method": "GET",
        "path": "/api/owner-operator/fleet/invites"
      },
      "response": {
        "body": {
          "invites": [
            {
              "email": "newdriver@example.com",
              "expiresAt": 1800000000000,
              "inviteId": "invite_abc",
              "token": "aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee"
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.invites": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.invites[*].email": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.invites[*].expiresAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.invites[*].inviteId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^invite_[a-zA-Z0-9_-]+$"
                }
              ]
            },
            "$.invites[*].token": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[a-f0-9-]+$"
                }
              ]
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.5.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "loadlead-api"
  }
}