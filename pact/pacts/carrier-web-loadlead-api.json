{
  "consumer": {
    "name": "carrier-web"
  },
  "interactions": [
    {
      "description": "a request for the carrier dashboard",
      "providerStates": [
        {
          "name": "a carrier org has 3 active drivers and 5 loads in flight"
        }
      ],
      "request": {
        "headers": {
          "Cookie": "token=test-carrier-admin-jwt"
        },
        "method": "GET",
        "path": "/api/org/org_carrier_test_1/dashboard"
      },
      "response": {
        "body": {
          "activeLoads": {
            "inTransit": 5,
            "unassigned": 0
          },
          "drivers": [
            {
              "driverId": "driver_abc123",
              "firstName": "Sam",
              "idvStatus": "VERIFIED",
              "lastName": "Driver",
              "status": "AVAILABLE"
            }
          ],
          "orgId": "org_carrier_test_1",
          "revenue": {
            "grossRevenue": 42000,
            "rpm": 2.45
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.activeLoads": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.activeLoads.inTransit": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.activeLoads.unassigned": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.drivers": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.drivers[*].driverId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^driver_[a-zA-Z0-9_-]+$"
                }
              ]
            },
            "$.drivers[*].firstName": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.drivers[*].idvStatus": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^(UNVERIFIED|PENDING|VERIFIED|REJECTED|EXPIRED)$"
                }
              ]
            },
            "$.drivers[*].lastName": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.drivers[*].status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^(AVAILABLE|ON_LOAD|UNAVAILABLE)$"
                }
              ]
            },
            "$.orgId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^org_[a-zA-Z0-9_-]+$"
                }
              ]
            },
            "$.revenue": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.revenue.grossRevenue": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.revenue.rpm": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request for the carrier dashboard from an ORG_DRIVER",
      "providerStates": [
        {
          "name": "an ORG_DRIVER is a member of the org but lacks dashboard:read permission"
        }
      ],
      "request": {
        "headers": {
          "Cookie": "token=test-org-driver-jwt"
        },
        "method": "GET",
        "path": "/api/org/org_carrier_test_1/dashboard"
      },
      "response": {
        "body": {
          "error": "Insufficient permission"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.error": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 403
      }
    },
    {
      "description": "a request to invite a DISPATCHER to the org",
      "providerStates": [
        {
          "name": "a carrier org owner is logged in"
        }
      ],
      "request": {
        "body": {
          "email": "dispatcher@example.com",
          "orgRole": "DISPATCHER"
        },
        "headers": {
          "Content-Type": "application/json",
          "Cookie": "token=test-carrier-admin-jwt"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/org/org_carrier_test_1/invitations"
      },
      "response": {
        "body": {
          "invitation": {
            "email": "dispatcher@example.com",
            "expiresAt": 1800000000000,
            "orgRole": "DISPATCHER",
            "token": "aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee"
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.invitation": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.invitation.email": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.invitation.expiresAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.invitation.orgRole": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^(OWNER|MANAGER|DISPATCHER|ORG_DRIVER|SHIPPER_USER)$"
                }
              ]
            },
            "$.invitation.token": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[a-f0-9-]+$"
                }
              ]
            }
          }
        },
        "status": 201
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.5.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "loadlead-api"
  }
}